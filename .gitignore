# .gitignore für ein Flask / Python Backend

# Byte-compiled / cache
__pycache__/
*.py[cod]
*~
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
.eggs/
*.egg-info/
.installed.cfg
pip-wheel-metadata/

# Virtual environments
.env
.env.*
venv/
venv*/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Pytest / test / coverage
.pytest_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover

# Migrations cache (keep migrations folder itself if you track migrations)
migrations/__pycache__/

# Flask instance folder (contains config & secrets)
instance/

# Databases
*.db
*.sqlite3

# Logs
logs/
*.log

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Python tool caches
.mypy_cache/
.pyre/
.pytype/

# Coverage / reports
htmlcov/
coverage/

# tox
.tox/

# Docker / Compose
docker-compose.override.yml

# Node / frontend (if present)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Misc
*.pem
*.key
*.crt
secrets.json

# Ignore local environment files
.local

# End of file
